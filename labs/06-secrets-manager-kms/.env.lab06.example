# Lab-06 | Secrets Manager + KMS
# Copy this file to .env.lab06 and populate with your values.
# .env.lab06 is gitignored — never commit it.

# AWS CLI named profile to use for all commands
AWS_PROFILE=your-aws-profile-name

# Region where all lab resources will be created
AWS_REGION=your-aws-region

# Your 12-digit AWS account ID
# Run: aws sts get-caller-identity --query Account --output text
ACCOUNT_ID=123456789012

# Lab prefix — used to name all resources consistently
LAB=lab06-secrets-kms

# ARN of the Lambda execution role created in Step B
# Run: aws iam get-role --role-name "${LAB}-lambda-exec" --query Role.Arn --output text
LAMBDA_ROLE_ARN=arn:aws:iam::123456789012:role/lab06-secrets-kms-lambda-exec

# ARN of the KMS CMK created in Step C
# Populated after running create-key in Step C3
KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ARN of the Secrets Manager secret created in Step C5
# Populated after running create-secret in Step C5
SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:lab06-secrets-kms/app-credentials-xxxxxx

# Secret name (used in Lambda environment variable and CLI commands)
SECRET_NAME=lab06-secrets-kms/app-credentials

# Lambda function names (derived from LAB prefix)
FN_RETRIEVE=lab06-secrets-kms-retrieveSecret
FN_ROTATE=lab06-secrets-kms-rotateSecretVersion

# IAM policy ARN for Secrets Manager + KMS permissions
# Populated after running create-policy in Step C4
SECRETS_KMS_POLICY_ARN=arn:aws:iam::123456789012:policy/lab06-secrets-kms-lambda-secrets-kms