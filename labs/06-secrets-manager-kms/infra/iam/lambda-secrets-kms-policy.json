{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSecretsManagerGet",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "arn:aws:secretsmanager:${AWS_REGION}:${ACCOUNT_ID}:secret:${LAB}/*"
    },
    {
      "Sid": "AllowKMSDecryptForSecret",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:DescribeKey"
      ],
      "Resource": "${KMS_KEY_ARN}"
    }
  ]
}
