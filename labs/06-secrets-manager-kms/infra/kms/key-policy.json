{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EnableRootAccountManagement",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::${ACCOUNT_ID}:root"
      },
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "AllowLambdaRoleDecrypt",
      "Effect": "Allow",
      "Principal": {
        "AWS": "${LAMBDA_ROLE_ARN}"
      },
      "Action": [
        "kms:Decrypt",
        "kms:DescribeKey",
        "kms:GenerateDataKey"
      ],
      "Resource": "*"
    }
  ]
}
